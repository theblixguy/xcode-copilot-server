{
  "name": "xcode-copilot-server",
  "version": "4.0.4",
  "description": "OpenAI-compatible proxy API server for Xcode, powered by GitHub Copilot",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theblixguy/xcode-copilot-server.git"
  },
  "engines": {
    "node": "25.6.0"
  },
  "bin": {
    "xcode-copilot-server": "bin/xcode-copilot-server.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "config.json5"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.check.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "14.0.3",
    "copilot-sdk-proxy": "3.0.0",
    "fastify": "5.8.2",
    "json5": "2.2.3",
    "koffi": "2.15.1",
    "plist": "3.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.3.5",
    "@types/plist": "3.0.5",
    "eslint": "10.0.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.0.18"
  }
}
