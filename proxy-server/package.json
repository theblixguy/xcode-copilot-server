{
  "name": "xcode-copilot-server",
  "version": "5.0.1",
  "description": "OpenAI-compatible proxy API server for Xcode, powered by GitHub Copilot",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theblixguy/xcode-copilot-server.git"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "xcode-copilot-server": "dist/index.js"
  },
  "files": [
    "dist/",
    "config.json5"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "oxfmt --write src/ test/",
    "fmt:check": "oxfmt --check src/ test/",
    "lint": "oxlint",
    "typecheck": "tsc -p tsconfig.check.json",
    "prepack": "cp ../README.md . && npm run build",
    "postpack": "rm -f README.md"
  },
  "dependencies": {
    "commander": "14.0.3",
    "copilot-sdk-proxy": "5.1.1",
    "fastify": "5.8.5",
    "json5": "2.2.3",
    "koffi": "2.16.1",
    "plist": "5.0.0",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/plist": "3.0.5",
    "llm-mock-server": "1.0.9",
    "oxfmt": "0.47.0",
    "oxlint": "1.63.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
