{
  "name": "xcode-copilot-server",
  "version": "4.0.7",
  "description": "OpenAI-compatible proxy API server for Xcode, powered by GitHub Copilot",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theblixguy/xcode-copilot-server.git"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "xcode-copilot-server": "dist/index.js"
  },
  "files": [
    "dist/",
    "patches/",
    "config.json5"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "oxfmt --write src/ test/",
    "fmt:check": "oxfmt --check src/ test/",
    "lint": "oxlint",
    "typecheck": "tsc -p tsconfig.check.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "14.0.3",
    "copilot-sdk-proxy": "4.1.1",
    "fastify": "5.8.4",
    "json5": "2.2.3",
    "koffi": "2.15.2",
    "plist": "3.1.0",
    "patch-package": "8.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "@types/plist": "3.0.5",
    "llm-mock-server": "1.0.7",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
